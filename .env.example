# Copy to .env and replace placeholders (never commit .env).
# cp .env.example .env

# PostgreSQL
DATABASE_URL=postgresql://postgres:root@localhost:5432/dt_videoapi_db

# Long random secret (min 8 chars); used when hashing stored API keys
API_KEY_PEPPER=change_me_to_a_long_random_secret_value

# Magicroll upstream (base URL should match api-2.json servers entry)
UPSTREAM_BASE_URL=https://api.magicroll.ai/api/v1
UPSTREAM_BEARER_TOKEN=magicroll_live_replace_with_your_enterprise_token

# Admin API: header X-Admin-Token (min 16 chars)
ADMIN_BOOTSTRAP_TOKEN=replace_with_a_long_random_admin_token

# JWT auth config (JWT_SECRET must be long random string, min 32 chars)
JWT_SECRET=replace_with_a_very_long_random_secret_32_chars_min
JWT_EXPIRES_IN_HOURS=24

# Optional — OpenAPI /docs servers URL when behind reverse proxy or tunnel
# GATEWAY_PUBLIC_URL=https://gateway.example.com

# Optional — set true only for local/dev open signup
# ALLOW_PUBLIC_REGISTRATION=true

# Optional — revoke other API keys after POST /auth/login
# AUTH_REVOKE_KEYS_ON_LOGIN=false

# Optional
# PORT=3000
# UPSTREAM_TIMEOUT_MS=120000
# CORS_ORIGINS=https://app.example.com,https://localhost:5173
